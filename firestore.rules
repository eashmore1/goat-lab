rules_version = '2';

// GOAT Lab Firestore rules.
// Paste into Firebase console -> Firestore Database -> Rules -> Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // Global daily leaderboard: anyone can READ (public board), but you can only
    // write your OWN entry, and only a valid 0-100 score with a short name.
    match /dailyLeaderboard/{date} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount', 'scoreHist']);
    }
    match /dailyLeaderboard/{date}/entries/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        // The GOAT badge is only trustworthy if it can't be faked: an entry may
        // claim goatPass only when the user actually owns the pass.
        && (!('goatPass' in request.resource.data)
          || request.resource.data.goatPass == false
          || get(/databases/$(database)/documents/users/$(uid)).data.goatPass == true);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // All-time XP leaderboard (the "grind" board — total XP earned, never resets).
    // Public read; you may only write your OWN entry, xp must be a non-negative
    // number, and a claimed goatPass badge must be backed by the real flag.
    match /xpLeaderboard/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.xp is number
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000000 // sanity ceiling (XP is client-computed)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && (!('goatPass' in request.resource.data)
          || request.resource.data.goatPass == false
          || get(/databases/$(database)/documents/users/$(uid)).data.goatPass == true);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Global all-time player counter. Public read; anonymous writes allowed
    // but constrained: only the totalPlayers field, only +1 increments.
    match /globalStats/totals {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['totalPlayers'])
        && request.resource.data.totalPlayers == 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPlayers'])
        && request.resource.data.totalPlayers == resource.data.totalPlayers + 1;
    }

    // A user's own profile doc — handle, streak mirror, and the GOAT Pass flag.
    // Owner can read/write their doc, BUT never the goatPass* fields: those are
    // written only by the Stripe webhook via the Admin SDK (which bypasses
    // rules). This stops anyone from granting themselves the pass for free.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(
          ['goatPass', 'goatPassAt', 'goatPassEmail', 'goatPassSession']);
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['goatPass', 'goatPassAt', 'goatPassEmail', 'goatPassSession']);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
    // Everything under a user's own space — saved builds, daily history/streak,
    // and anything we add later. Owner only.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Push-notification tokens (daily reminder). Anyone (incl. signed-out) can
    // register/remove their own device token; only the server (Admin SDK) reads
    // them to send. Not publicly readable.
    match /pushTokens/{token} {
      allow read: if false;
      allow create, update: if request.resource.data.keys().hasOnly(['uid', 'ua', 'createdAt']);
      allow delete: if true;
    }
  }
}
