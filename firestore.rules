rules_version = '2';

// GOAT Lab Firestore rules.
// Paste into Firebase console -> Firestore Database -> Rules -> Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // Global daily leaderboard: anyone can READ (public board), but you can only
    // write your OWN entry, and only a valid 0-100 score with a short name.
    match /dailyLeaderboard/{date} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount']);
    }
    match /dailyLeaderboard/{date}/entries/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Global all-time player counter. Public read; anonymous writes allowed
    // but constrained: only the totalPlayers field, only +1 increments.
    match /globalStats/totals {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['totalPlayers'])
        && request.resource.data.totalPlayers == 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPlayers'])
        && request.resource.data.totalPlayers == resource.data.totalPlayers + 1;
    }

    // Everything under a user's own space — profile (handle), saved builds,
    // daily history/streak, and anything we add later. Owner only.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
